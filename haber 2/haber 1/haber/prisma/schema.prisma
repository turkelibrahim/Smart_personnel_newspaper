generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String?  @unique
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preference       UserPreference?
  bookmarks        Bookmark[]
  readingHistory   ReadingHistory[]
  personalEditions PersonalEdition[]
  adminLogs        AdminLog[]
}

model UserPreference {
  id                    String   @id @default(uuid())
  userId                String   @unique
  categoryId            String?
  weight                Float?
  profession            String?
  interests             String?
  blockedTopics         String?
  preferredReadingDepth String?
  preferredTone         String?
  location              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}

model NewsSource {
  id               String    @id
  name             String
  type             String    @default("NEWS_PORTAL")
  baseUrl          String
  rssUrl           String?
  url              String?
  language         String?
  country          String?
  reliabilityScore Float     @default(50.0)
  trustScore       Float     @default(50.0)
  isActive         Boolean   @default(true)
  lastFetchedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  articles  Article[]
  fetchLogs FetchLog[]

  @@index([isActive])
  @@index([language, country])
  @@map("Source")
}

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  color       String?
  icon        String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  articles    Article[]
  preferences UserPreference[]

  @@index([isActive, sortOrder])
}

model Article {
  id                   String   @id @default(uuid())
  sourceId             String
  title                String
  slug                 String   @unique
  summary              String?
  content              String?
  originalUrl          String
  url                  String
  imageUrl             String?
  author               String?
  language             String?
  publishedAt          DateTime
  fetchedAt            DateTime @default(now())
  categoryId           String?
  category             String?
  reliabilityScore     Float    @default(50.0)
  trustScore           Float    @default(50.0)
  popularityScore      Float    @default(0.0)
  personalizationScore Float    @default(0.0)
  duplicateHash        String?
  isDuplicate          Boolean  @default(false)
  isActive             Boolean  @default(true)
  importanceScore      Float    @default(50.0)
  readingTime          Int?
  sentiment            Float?
  tags                 String?
  relatedProfessions   String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  source          NewsSource               @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  categoryRef     Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  articleTags     ArticleTag[]
  readingHistory  ReadingHistory[]
  bookmarks       Bookmark[]
  editionArticles PersonalEditionArticle[]

  @@index([sourceId, publishedAt])
  @@index([categoryId, publishedAt])
  @@index([isActive, isDuplicate])
  @@index([duplicateHash])
}

model Tag {
  id   String @id @default(uuid())
  name String
  slug String @unique

  articleTags ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}

model ReadingHistory {
  id          String   @id @default(uuid())
  userId      String
  articleId   String
  readAt      DateTime @default(now())
  readingTime Int?
  scrollDepth Float?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([articleId, readAt])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("SavedArticle")
}

model PersonalEdition {
  id        String   @id @default(uuid())
  userId    String
  title     String
  type      String   @default("DAILY")
  date      DateTime
  status    String   @default("DRAFT")
  createdAt DateTime @default(now())

  user     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles PersonalEditionArticle[]

  @@index([userId, date])
  @@index([status, type])
  @@unique([userId, date, type])
}

model PersonalEditionArticle {
  id        String  @id @default(uuid())
  editionId String
  articleId String
  position  Int
  reason    String?

  edition PersonalEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  article Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([editionId, articleId])
  @@unique([editionId, position])
  @@index([articleId])
}

model FetchLog {
  id           String    @id @default(uuid())
  sourceId     String
  status       String
  message      String?
  fetchedCount Int       @default(0)
  errorCount   Int       @default(0)
  startedAt    DateTime
  finishedAt   DateTime?

  source NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, startedAt])
  @@index([status, startedAt])
}

model AdminLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model EventAnnouncement {
  id          String    @id @default(uuid())
  title       String
  description String?
  category    String
  startsAt    DateTime
  endsAt      DateTime?
  priority    String    @default("MEDIUM")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category, startsAt])
  @@index([isActive, priority])
}
